# ===== 데이터베이스 (Supabase PostgreSQL) =====
# Supabase 대시보드 > Project Settings > Database > Connection string 에서 확인
# DATABASE_URL: Transaction pooler 주소 (포트 6543, pgbouncer=true 필수)
# DIRECT_URL:   Direct connection 주소 (포트 5432, 마이그레이션용)
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ===== 관리자 비밀번호 (로그인용) =====
ADMIN_PASSWORD="1111"

# ===== Supabase Storage (사진 업로드) =====
# Supabase 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# service_role 키 (서버에서만 사용, 절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# 사진을 저장할 버킷 이름 (Supabase Storage에서 public 버킷으로 생성)
SUPABASE_STORAGE_BUCKET="vendor-photos"
